Option Explicit

'Assumption:
'1. All dates from Planner extract file are MM/DD/YYYY format

'*==============How to Install this code Copy/Paste=============*
'1. In Workbook, create a new sheet and rename it "s_Main"
'2. In Cell A1, write the text "MESSAGE"
'3. In Cell A2, write the Text "FILE LOCATION"
'4. In VBA, create a new MODULE and copy/paste me
'5. In Sheet "s_Main", insert a Button (Form Control) and
'   assign Macro to "s_Main"

'*==============How to Use======================================*
'1. In Sheet "s_Main", Enter the file location path of excel file
'   including the file extension exported from the Planner Web
'2. Click the Form Button to EXECUTE

'*==============Expected Output=================================*
'1. A new file will be created in Same folder where the input file
'   is located.

Dim gstr_ErrorMessage As String

Const gcExportFileName As String = "PlannerOut.xlsx"

Const gcSheet1 As String = "Raw"
Const gcSheet2 As String = "Massage"
Const gcSheet3 As String = "Pivot"

Const gcValueDesc1 As String = "Project Details"

Sub s_Main()

  On Error GoTo MyError:
  Application.DisplayAlerts = False
    
  Dim oWSMacro As Worksheet
  Dim colRawData As New Collection
  Dim colTemp As Collection
  Dim colOutput As New Collection
  Dim objRec As Object
  Dim objTemp As Object
  Dim strFilePath As String
  Dim strTemp As String
  Dim strPath As String
  
  Dim oWBMain As Workbook
  
  Const cSub As String = "s_Main"

  Set oWSMacro = ThisWorkbook.Worksheets(cSub)
  
  gstr_ErrorMessage = ""
  
  'Clear Output
  oWSMacro.Range("B1").Value2 = ""
  
  'Get Data
  strFilePath = oWSMacro.Range("B2").Value2
  Set colRawData = f_getRawData(strFilePath)
  If gstr_ErrorMessage <> "" Then
    GoTo MyError
  End If
  
  'Process each record of row data
  'expectation 1 raw record is many output record
  For Each objRec In colRawData
    Set colTemp = Nothing
    Set colTemp = f_getOutput(objRec)
    If Not colTemp Is Nothing Then
      For Each objTemp In colTemp
        colOutput.Add objTemp
      Next objTemp
    End If
  Next objRec
  If gstr_ErrorMessage <> "" Then
    GoTo MyError
  End If
  
  'Create the new workbook
  Set oWBMain = Workbooks.Add
  
  'Fill up with the Raw
  Call f_createSheet( _
    gcSheet1, colRawData, oWBMain)
  If gstr_ErrorMessage <> "" Then
    GoTo MyError
  End If

  'Fill up with the Output
  Call f_createSheet( _
    gcSheet2, colOutput, oWBMain)
  If gstr_ErrorMessage <> "" Then
    GoTo MyError
  End If
  
  'Create Pivot Sheet
  Call f_createPivot(colOutput, oWBMain)
  If gstr_ErrorMessage <> "" Then
    GoTo MyError
  End If
  
  'Hide worksheet (We only want the Pivot Table to show by default)
  'Worksheet can be unhide if needed for other purpose
  oWBMain.Sheets(gcSheet1).Visible = xlHidden
  oWBMain.Sheets(gcSheet2).Visible = xlHidden
  
  'Prepare full path for export
  strTemp = Left(strFilePath, InStrRev(strFilePath, "\") - 1)
  strPath = strTemp & "\" & gcExportFileName
  
  'Save Workbook
  oWBMain.SaveAs Filename:=strPath
  
  Exit Sub
  
MyError:
  If gstr_ErrorMessage = "" Then
    gstr_ErrorMessage = Err.Description
  End If
  On Error Resume Next
  oWSMacro.Range("B1").Value2 = gstr_ErrorMessage
  
End Sub

Function f_createPivot(colData As Collection, oWB As Workbook)
  
  Dim oWSPivot As Worksheet
  Dim oWSSource As Worksheet
  Dim lMaxRow As Integer
  Dim lMaxColN As Integer
  
  Dim objPivotTable As PivotTable
  
  Dim strTabName As String
  Dim strSourceData As String
  Dim strDestination As String
  
  Const cPivotColStart As Integer = 1
  
  On Error GoTo MyError:
  
  'Get Source Worksheet
  Set oWSSource = oWB.Sheets(gcSheet2)
  
  'Create New Sheet for Pivot Data
  Set oWSPivot = oWB.Sheets.Add(After:=oWB.Sheets(oWB.Sheets.Count))
  oWSPivot.Name = gcSheet3
  
  'Get Max Row of Data Table
  lMaxRow = oWSSource.Cells.Find("*", searchorder:=xlByRows, searchdirection:=xlPrevious).Row
  lMaxColN = oWSSource.Cells.Find("*", searchorder:=xlByColumns, searchdirection:=xlPrevious).Column
  
  'Prepare Tablename, Source and Target
  strTabName = "PivotTable01_" & oWSPivot.Name
  strSourceData = oWSSource.Name & "!R1C1:R" & lMaxRow & "C" & lMaxColN
  strDestination = oWSPivot.Name & "!R1C" & cPivotColStart
  
  'Create Pivot Table
  oWB.PivotCaches.Create(SourceType:=xlDatabase, SourceData:= _
  strSourceData, Version:=6).CreatePivotTable TableDestination:= _
  strDestination, TableName:=strTabName, DefaultVersion:=6
  
  'Start Preparing the Pivot
  Set objPivotTable = oWSPivot.PivotTables(strTabName)
   
  oWB.ShowPivotTableFieldList = False     'Hide PivotTable Fields
  
  '==========Design=========================
  objPivotTable.RowGrand = False
  objPivotTable.ColumnGrand = False
  objPivotTable.ShowTableStyleRowStripes = True     ' Banded Rows
  objPivotTable.ShowTableStyleColumnStripes = True  ' Banded Columns
  objPivotTable.TableStyle2 = "PivotStyleMedium2"
  
  'Report Table Layout
  objPivotTable.RowAxisLayout xlTabularRow
  
  '==========Pivot Table Options============
  
  '>>>>>Display
  'Display field captions and filter drop downs
  objPivotTable.DisplayFieldCaptions = False
  
  'Show expand/collapse button
  objPivotTable.ShowDrillIndicators = False
  
  '>>>>>Layout
  'Merge and center cells with label
  objPivotTable.MergeLabels = True
  
  '==========Adding Columns=================
  Call f_addPivotField(objPivotTable, xlColumnField, "MONTH")
  Call f_addPivotField(objPivotTable, xlColumnField, "DAYS_NUM")
  Call f_addPivotField(objPivotTable, xlColumnField, "DAYS_WEEK")
  
  '==========Adding Rows=================
  Call f_addPivotField(objPivotTable, xlRowField, "CHECKLIST ITEMS")
  Call f_addPivotField(objPivotTable, xlRowField, "BUCKET NAME")
  Call f_addPivotField(objPivotTable, xlRowField, "TASK NAME")
  
  '==========Adding Values=================
  objPivotTable.AddDataField objPivotTable.PivotFields("PROGRESS"), _
      gcValueDesc1
      
  'AutoFit Pivot
  objPivotTable.TableRange2.Columns.AutoFit
  objPivotTable.TableRange2.Rows.AutoFit
  
  'Fill Value with Red
  Call f_conditionFormatCell(oWSPivot)

  Exit Function
  
MyError:
  gstr_ErrorMessage = Err.Description
  
  End Function
  
Function f_addPivotField(objPivot As PivotTable, vOrient As Variant, strName As String)

  With objPivot.PivotFields(strName)
    .Orientation = vOrient
    .Subtotals = Array(False, False, False, False, False, False, False, False, False, False, _
      False, False)
  End With
  
End Function
  
Function f_conditionFormatCell(oWSPivot As Worksheet)

  Dim objPivotTable As PivotTable
  Dim objPivotField As PivotField
  Dim objCondFormat As FormatCondition


  'Get Pivot Table
  Set objPivotTable = oWSPivot.PivotTables(1)
  
  'Get PivotField
  Set objPivotField = objPivotTable.PivotFields(gcValueDesc1)
  
  'Delete Initial condition format if any
  On Error Resume Next
  objPivotField.DataRange.FormatConditions.Delete
  On Error GoTo 0

  'Set Condition Formatting
  Set objCondFormat = objPivotField.DataRange.FormatConditions.Add( _
              Type:=xlCellValue, _
              Operator:=xlEqual, _
              Formula1:="=1")
              
  'Fill cell with RED
  objCondFormat.Interior.Color = RGB(255, 0, 0)
  objCondFormat.Font.Color = RGB(255, 255, 255)


End Function

Function f_createSheet( _
  strSheetName As String, _
  colData As Collection, _
  ByRef oWB As Workbook)
  
  Dim oWs As Worksheet
  Dim objRec As Object
  Dim vKey As Variant
  Dim strVal As String
  Dim iRow As Long
  Dim iCol As Long

  On Error GoTo MyError:
  
  'Create new worksheet
  'If sheet1 exists, use that one just rename it
  If UCase(oWB.Sheets(1).Name) = "SHEET1" Then
    Set oWs = oWB.Sheets(1)
  Else
    Set oWs = oWB.Sheets.Add(After:=oWB.Sheets(oWB.Sheets.Count))
  End If
  oWs.Name = strSheetName
  
  'Fill Up Header
  iCol = 1
  For Each vKey In colData(1)
    strVal = vKey
    oWs.Cells(1, iCol).Value2 = strVal
    iCol = iCol + 1
  Next vKey
  
  'Populate Worksheet from Collection of Data
  iRow = 2
  For Each objRec In colData
      
    'Fill Data
    iCol = 1
    For Each vKey In objRec
      strVal = objRec(vKey)
      oWs.Cells(iRow, iCol).Value2 = "'" & strVal
      iCol = iCol + 1
    Next vKey
      
    iRow = iRow + 1
  
  Next objRec
  
  Exit Function
  
MyError:
  gstr_ErrorMessage = Err.Description

End Function

Function f_getOutput(objRec As Object) As Collection

  On Error GoTo MyError:
  
  Dim dtStart As Date
  Dim dtEnd As Date
  Dim dtDaily As Date
  Dim iNumOfDays As Integer
  Dim i As Integer
  Dim vKey As Variant
  Dim objOut As Object
  Dim strVal As String
  Dim strStart As String
  Dim strEnd As String
  
  Dim colOutput As New Collection
  
  'Calculate Number of Days between Start and End Date
  strStart = objRec("START DATE")
  strEnd = objRec("DUE DATE")
  If strStart = "" Then
    'Set same as End Date
    strStart = strEnd
  End If
  If strEnd = "" Then
    'Set same as start date
    strEnd = strStart
  End If
  
  If strStart = "" Or strEnd = "" Then
    'Skip Record with blank date
    Exit Function
  End If
  
  dtStart = f_ConvStr2Date(strStart)
  dtEnd = f_ConvStr2Date(strEnd)
  
  iNumOfDays = DateDiff("d", dtStart, dtEnd)
  
  For i = 0 To iNumOfDays
  
    Set objOut = Nothing
    Set objOut = CreateObject("Scripting.Dictionary")
  
    'Copy the initial details
    For Each vKey In objRec
      strVal = objRec(vKey)
      objOut.Add vKey, strVal
    Next vKey
    
    'Start Inserting new columns here
    
    'Daily
    dtDaily = DateAdd("d", i, dtStart)
    strVal = Format(dtDaily, "YYYY-MM-DD")
    objOut.Add "DAILY", strVal
    
    'Daily in Number (DD)
    strVal = Format(dtDaily, "DD")
    objOut.Add "DAYS_NUM", strVal
    
    'Daily in WeekDay(MON-SUN)
    strVal = UCase(Format(dtDaily, "DDD"))
    If strVal = "THU" Then
      strVal = "TH"
    ElseIf strVal = "SUN" Then
      strVal = "SU"
    Else
      strVal = Left(strVal, 1)
    End If
    objOut.Add "DAYS_WEEK", strVal
    
    'Month
    strVal = UCase(Format(dtDaily, "MMM-YY"))
    objOut.Add "MONTH", strVal
    
    If objOut("DAYS_WEEK") = "S" Or _
       objOut("DAYS_WEEK") = "SU" Then
       
      'Exclude Saturday and Sunday
      
    Else
      colOutput.Add objOut
    End If
  
  Next i
  
  Set f_getOutput = colOutput

  Exit Function
  
MyError:
  gstr_ErrorMessage = Err.Description

End Function

Function f_getRawData(strPath As String) As Collection

  On Error GoTo MyError:

  Dim oWBTemp As Workbook
  Dim oWSTemp As Worksheet
  Dim lMaxRow As Integer
  Dim lMaxColN As Integer
  Dim strRange As String
  Dim strColL As String
  Dim tData As Variant
  Dim sdata As Variant
  
  'Validate FilePath
  If Dir(strPath) = "" Or strPath = "" Then
    gstr_ErrorMessage = "File Does not exists!"
    Exit Function
  End If

  'Get Planner details
  Set oWBTemp = Workbooks.Open(strPath)
  Set oWSTemp = oWBTemp.Worksheets(1)
  
  'Get Max Row and Col
  lMaxRow = oWSTemp.Cells.Find("*", searchorder:=xlByRows, searchdirection:=xlPrevious).Row
  lMaxColN = oWSTemp.Cells.Find("*", searchorder:=xlByColumns, searchdirection:=xlPrevious).Column
  
  'Convert Column Number to Letter
  strColL = Split(Cells(1, lMaxColN).Address(False, False), "1")(0)
  
  'Prepare Max Range
  strRange = "A1" & ":" & strColL & lMaxRow
  
  'Get Data
  tData = oWSTemp.Range(strRange)
   
  'Close Workbook
  oWBTemp.Close
  
  Set f_getRawData = f_variant2Collection(tData)
  
  Exit Function
  
MyError:
  gstr_ErrorMessage = Err.Description

End Function

Function f_variant2Collection(ByVal v As Variant) As Collection

  On Error GoTo MyError:
  
  Dim col As New Collection
  Dim dict As Object
  Dim r As Long, c As Long
  Dim header As String

  ' Safety checks
  If Not IsArray(v) Then
    gstr_ErrorMessage = "Input not a variant"
    Exit Function
  End If

  If UBound(v, 1) < 2 Then
    gstr_ErrorMessage = "Variant Empty"
    Exit Function
  End If

  ' Row 1 = headers, Row 2+ = data
  For r = LBound(v, 1) + 1 To UBound(v, 1)

    Set dict = CreateObject("Scripting.Dictionary")
  
    For c = LBound(v, 2) To UBound(v, 2)
      header = CStr(v(LBound(v, 1), c)) ' header from row 1
      header = UCase(header)
  
      If Len(header) > 0 Then
        dict(header) = v(r, c)
      End If
    Next c
  
    col.Add dict
  Next r

  Set f_variant2Collection = col
  
  Exit Function

MyError:

  gstr_ErrorMessage = Err.Description

End Function

Function f_ConvStr2Date(ByVal dateText As String) As Date

    f_ConvStr2Date = DateSerial( _
        CLng(Right(dateText, 4)), _
        CLng(Left(dateText, 2)), _
        CLng(Mid(dateText, 4, 2)) _
    )
    
End Function
